#!/usr/bin/env bash
# Keep generated / derived files in sync with the commit:
#   1. README's branch-githack link points at the current branch.
#   2. index.html's build timestamp matches the commit moment.
# Both scripts are idempotent; re-stage the files if they actually moved.
set -e
repo="$(git rev-parse --show-toplevel)"
"$repo/scripts/sync-readme-branch.sh"
"$repo/scripts/sync-build-timestamp.sh"
if ! git diff --quiet -- README.md; then
  git add README.md
fi
if ! git diff --quiet -- index.html; then
  git add index.html
fi
